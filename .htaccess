# Badri Homes - Apache Server Configuration for SEO & Performance

# ===== COMPRESSION & CACHING =====
# Enable Gzip compression for faster page loads (Core Web Vitals optimization)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Browser caching for static assets (improves performance)
<IfModule mod_expires.c>
  ExpiresActive On

  # Images (cache for 1 year)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # CSS & JavaScript (cache for 1 month)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"

  # Fonts (cache for 1 year)
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType application/x-font-otf "access plus 1 year"
  ExpiresByType application/x-font-woff "access plus 1 year"
  ExpiresByType application/x-font-woff2 "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # HTML (cache for 1 day - allows updates without clearing browser cache)
  ExpiresByType text/html "access plus 1 day"

  # Default expiration
  ExpiresDefault "access plus 2 days"
</IfModule>

# ===== SEO & SECURITY =====
# Enforce HTTPS (redirect all HTTP traffic to HTTPS)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove index.html from URLs (hide default document)
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP
  RewriteRule ^index\.html$ / [R=301,L]

  # Redirect old local-guide.html to new localguide.html
  RewriteRule ^local-guide\.html$ /localguide.html [R=301,L]

  # Remove trailing slashes (consistency for canonical URLs)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # Prevent duplicate content with www (choose one and redirect)
  # To enforce www, uncomment the following:
  # RewriteCond %{HTTP_HOST} !^www\.
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

  # To remove www, uncomment the following:
  # RewriteCond %{HTTP_HOST} ^www\.
  # RewriteRule ^(.*)$ https://%{HTTP_HOST:4}/$1 [R=301,L]

  # Prevent access to hidden files and directories
  RewriteRule "^\." - [F]
</IfModule>

# ===== SECURITY HEADERS =====
# Prevent MIME type sniffing
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"

  # Prevent clickjacking
  Header set X-Frame-Options "SAMEORIGIN"

  # Enable XSS protection in older browsers
  Header set X-XSS-Protection "1; mode=block"

  # Referrer Policy (control referrer information)
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy (disable unnecessary browser features)
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
</IfModule>

# ===== DISABLE DIRECTORY LISTING =====
Options -Indexes

# ===== BLOCK MALICIOUS REQUESTS =====
# Block SQL injection attempts
<IfModule mod_rewrite.c>
  RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
  RewriteCond %{QUERY_STRING} UNION.*SELECT [NC,OR]
  RewriteCond %{QUERY_STRING} union.*select [NC]
  RewriteRule ^ - [F]
</IfModule>

# ===== CHARSET ENCODING =====
# Default charset for text files
AddDefaultCharset UTF-8

# ===== CUSTOM ERROR PAGES =====
# You can customize error pages for better user experience
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html
